{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "brain_hologram.glb",
      "use": "@vercel/static"
    },
    {
      "src": "tesseract.html",
      "use": "@vercel/static"
    }
